{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/sales/layout,_N_T_/sales/orders/layout,_N_T_/sales/orders/page,_N_T_/sales/orders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/sales/orders/__PAGE__",
    "/sales/orders",
    "/sales",
    "/_index",
    "/_head"
  ]
}